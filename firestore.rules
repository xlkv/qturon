rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function userId() { return request.auth.uid; }

    // Role'ni Firestore /users/{uid} doc'idan o'qiymiz (custom claims ishlatmaymiz).
    function role() {
      return get(/databases/$(database)/documents/users/$(userId())).data.role;
    }
    function isSuperAdmin() { return isSignedIn() && role() == 'super_admin'; }
    function isAdmin() { return isSignedIn() && role() == 'admin'; }

    function paidUnchanged() {
      return !('paid' in request.resource.data.diff(resource.data).affectedKeys());
    }
    function paidIsTrueOnCreate() {
      return request.resource.data.paid == true;
    }
    function readableAsPaid(data) {
      return isSuperAdmin() || data.paid == true;
    }

    // /users — user o'z doc'ini o'qiy oladi, super-admin hammasini boshqaradi.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow create, update, delete: if isSuperAdmin();
    }

    // /wells — global collection.
    match /wells/{wellId} {
      allow read: if isSignedIn() && readableAsPaid(resource.data);
      allow create: if (isSuperAdmin() || isAdmin()) && paidIsTrueOnCreate();
      allow update: if isSuperAdmin() ||
                     (isAdmin() && resource.data.paid == true && paidUnchanged());
      allow delete: if isSuperAdmin() ||
                     (isAdmin() && resource.data.paid == true);
    }

    // /pipes — global collection.
    match /pipes/{pipeId} {
      allow read: if isSignedIn() && readableAsPaid(resource.data);
      allow create: if (isSuperAdmin() || isAdmin()) && paidIsTrueOnCreate();
      allow update: if isSuperAdmin() ||
                     (isAdmin() && resource.data.paid == true && paidUnchanged());
      allow delete: if isSuperAdmin() ||
                     (isAdmin() && resource.data.paid == true);
    }

    // /masters — global collection.
    match /masters/{masterId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin() || isAdmin();
    }

    // /logs
    match /logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /rate_limit/{installId} {
      allow read, write: if false;
    }
  }
}
