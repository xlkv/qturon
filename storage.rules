rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() { return request.auth != null; }
    function role() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role;
    }
    function isSuperAdmin() { return isSignedIn() && role() == 'super_admin'; }
    function isAdmin() { return isSignedIn() && role() == 'admin'; }

    match /wells/{wellId}/{file} {
      allow read: if isSignedIn();
      allow write: if (isSuperAdmin() || isAdmin())
                     && request.resource.size < 5 * 1024 * 1024
                     && request.resource.contentType.matches('image/.*');
    }

    match /pipes/{pipeId}/{file} {
      allow read: if isSignedIn();
      allow write: if (isSuperAdmin() || isAdmin())
                     && request.resource.size < 5 * 1024 * 1024
                     && request.resource.contentType.matches('image/.*');
    }

    match /tmp/{userId}/{file} {
      allow read, write: if isSignedIn() && request.auth.uid == userId
                          && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
